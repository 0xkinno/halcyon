# Solana Devnet RPC URL
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Service / Solver Keypair Secret Key (represented as a JSON byte array)
# Generate one using solana-keygen new
SERVICE_WALLET_SECRET_KEY=[1,2,3,4,5,...]

# Network switch (devnet | mainnet)
NEXT_PUBLIC_TXLINE_NETWORK=devnet
